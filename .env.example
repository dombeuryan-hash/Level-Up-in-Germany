# --- Site (liens absolus dans les e-mails PDF) ---
NEXT_PUBLIC_SITE_URL=https://www.levelupingermany.de

# --- SEO (optionnel : Search Console) ---
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your-content-value-from-google

# --- Base de données (newsletter / PDF) — SQLite local ---
# Fichier créé dans prisma/ après: npx prisma migrate dev
DATABASE_URL="file:./dev.db"

# --- Formulaires (e-mail via Resend) ---
RESEND_API_KEY= 
# Destinataire des soumissions (contact, join, workshops, etc.)
FORMS_TO_EMAIL=info@levelupingermany.de
# Expéditeur vérifié dans Resend (domaine ou onboarding@resend.dev pour tests)
FORMS_FROM_EMAIL=Level Up in Germany <onboarding@resend.dev>
# Expéditeur des e-mails « PDF événement » (doit être autorisé dans Resend)
NEWSLETTER_FROM_EMAIL=Level Up in Germany <info@levelupingermany.de>

# --- Cloudflare Turnstile (captcha) ---
# Clé publique (visible côté client)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# Clé secrète (serveur uniquement) — obligatoire en production
TURNSTILE_SECRET_KEY=

# --- WhatsApp « Rejoindre » (lien groupe recommandé) ---
# Si vide : wa.me avec numéro par défaut + message prérempli selon la langue
NEXT_PUBLIC_WHATSAPP_JOIN_URL=
