// Newsletter leads (event PDF downloads). Local: DATABASE_URL="file:./dev.db"
// Production: use PostgreSQL (Neon, etc.) — same schema, change provider + url.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model NewsletterSubscriber {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  source    String
  consent   Boolean  @default(false)
  name      String?
  tags      String?  @default("levelup_event")

  @@map("newsletter_subscribers")
}

model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now()) @map("created_at")
  read      Boolean  @default(false)

  @@map("contact_messages")
}

model BlogPost {
  id         String   @id @default(uuid())
  title      String
  body       String
  coverImage String?
  author     String   @default("Équipe Level Up in Germany")
  category   String?
  published  Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("blog_posts")
}

model TeamMember {
  id       String  @id @default(uuid())
  name     String  @unique
  bioDe    String? @default("")
  bioEn    String? @default("")
  bioFr    String? @default("")
  linkedin String? @default("")
  imageUrl String? @default("")

  @@map("team_members")
}

model Media {
  id        String   @id @default(uuid())
  filename  String
  url       String
  altText   String?  @default("")
  category  String   @default("general")
  size      Int?
  mimeType  String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("media_files")
}
