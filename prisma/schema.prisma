// Newsletter leads (event PDF downloads). Local: DATABASE_URL="file:./dev.db"
// Production: use PostgreSQL (Neon, etc.) — change provider to "postgresql" + update DATABASE_URL.
// LOCAL DEV: provider = "sqlite"  →  run: npx prisma db push
// PRODUCTION: provider = "postgresql"  →  run: npx prisma migrate deploy
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model NewsletterSubscriber {
  id               String   @id @default(uuid())
  email            String   @unique
  createdAt        DateTime @default(now()) @map("created_at")
  source           String
  consent          Boolean  @default(false)
  name             String?
  tags             String?  @default("levelup_event")
  firstName        String?  @map("first_name")
  lastName         String?  @map("last_name")
  address          String?
  city             String?
  status           String   @default("active")
  unsubscribeToken String?  @unique @map("unsubscribe_token")
  eventCommunicationLeads EventCommunicationLead[]

  @@map("newsletter_subscribers")
}

model CommunicationSettings {
  id                         String   @id @default(uuid())
  isCommunicationModeActive  Boolean  @default(false) @map("is_communication_mode_active")
  popupDelaySeconds          Int      @default(5) @map("popup_delay_seconds")
  title                      String   @default("Something is coming...")
  description                String   @default("Be among the first to receive updates about the next Level Up event.")
  buttonText                 String   @default("Join the list") @map("button_text")
  eventId                    String?  @unique @map("event_id")
  createdAt                  DateTime @default(now()) @map("created_at")
  updatedAt                  DateTime @updatedAt @map("updated_at")
  event                      Event?   @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@map("communication_settings")
}

model EventCommunicationLead {
  id                    String                @id @default(uuid())
  eventId               String                @map("event_id")
  email                 String
  firstName             String?               @map("first_name")
  subscriberId          String?               @map("subscriber_id")
  source                String                @default("event_communication_popup")
  createdAt             DateTime              @default(now()) @map("created_at")
  updatedAt             DateTime              @updatedAt @map("updated_at")
  event                 Event                 @relation(fields: [eventId], references: [id], onDelete: Cascade)
  subscriber            NewsletterSubscriber? @relation(fields: [subscriberId], references: [id], onDelete: SetNull)

  @@unique([eventId, email])
  @@index([subscriberId])
  @@map("event_communication_leads")
}

model NewsletterCampaign {
  id          String    @id @default(uuid())
  subject     String
  previewText String?   @map("preview_text")
  titleText   String?   @map("title_text")
  bodyContent      String    @map("body_content")
  headerImageUrl   String?   @map("header_image_url")
  campaignImageUrl String?   @map("campaign_image_url")
  ctaLabel         String?   @map("cta_label")
  ctaUrl           String?   @map("cta_url")
  footerNote       String?   @map("footer_note")
  status      String    @default("draft")
  sentAt      DateTime? @map("sent_at")
  sentCount   Int       @default(0) @map("sent_count")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("newsletter_campaigns")
}

model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now()) @map("created_at")
  read      Boolean  @default(false)

  @@map("contact_messages")
}

model Member {
  id                String    @id @default(uuid())
  firstName         String    @map("first_name")
  lastName          String    @map("last_name")
  birthDate         DateTime  @map("birth_date")
  address           String
  email             String    @unique
  phone             String?
  activityDomain    String    @map("activity_domain")
  motivation        String?
  helpDomains       String    @map("help_domains")
  applicationStatus String    @default("pending") @map("application_status")
  rejectionReason   String?   @map("rejection_reason")
  membershipFeePaid Boolean   @default(false) @map("membership_fee_paid")
  lastPaymentDate   DateTime? @map("last_payment_date")
  consentGiven      Boolean   @default(true) @map("consent_given")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@map("members")
}

model HeroSlide {
  id         String   @id @default(uuid())
  imageUrl   String   @map("image_url")
  isMain     Boolean  @default(false) @map("is_main")
  titleFr    String?  @map("title_fr")
  titleDe    String?  @map("title_de")
  titleEn    String?  @map("title_en")
  subtitleFr String?  @map("subtitle_fr")
  subtitleDe String?  @map("subtitle_de")
  subtitleEn String?  @map("subtitle_en")
  altTextFr  String?  @map("alt_text_fr")
  altTextDe  String?  @map("alt_text_de")
  altTextEn  String?  @map("alt_text_en")
  linkType   String?  @map("link_type")
  linkTarget String?  @map("link_target")
  isActive   Boolean  @default(true) @map("is_active")
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([isActive, sortOrder])
  @@map("hero_slides")
}

model HomeButton {
  id           String   @id @default(uuid())
  labelFr      String   @map("label_fr")
  labelDe      String   @map("label_de")
  labelEn      String   @map("label_en")
  linkType     String   @default("internal") @map("link_type")
  linkTarget   String   @map("link_target")
  colorVariant String   @default("red") @map("color_variant")
  displayOrder Int      @default(0) @map("display_order")
  isActive     Boolean  @default(true) @map("is_active")
  isPrimary    Boolean  @default(false) @map("is_primary")
  openInNewTab Boolean  @default(false) @map("open_in_new_tab")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([isActive, displayOrder])
  @@map("home_buttons")
}

model SiteConfig {
  id                      String   @id @default("singleton")
  headerLogoUrl           String?  @map("header_logo_url")
  headerJoinLabelFr       String?  @map("header_join_label_fr")
  headerJoinLabelDe       String?  @map("header_join_label_de")
  headerJoinLabelEn       String?  @map("header_join_label_en")
  headerJoinLink          String?  @map("header_join_link")
  headerJoinOpenInNewTab  Boolean  @default(false) @map("header_join_open_in_new_tab")
  headerSponsorLabelFr    String?  @map("header_sponsor_label_fr")
  headerSponsorLabelDe    String?  @map("header_sponsor_label_de")
  headerSponsorLabelEn    String?  @map("header_sponsor_label_en")
  headerSponsorLink       String?  @map("header_sponsor_link")
  headerSponsorOpenInNewTab Boolean @default(false) @map("header_sponsor_open_in_new_tab")
  membershipHeroHeadingFr String?  @map("membership_hero_heading_fr")
  membershipHeroHeadingDe String?  @map("membership_hero_heading_de")
  membershipHeroHeadingEn String?  @map("membership_hero_heading_en")
  membershipHeroSubFr     String?  @map("membership_hero_sub_fr")
  membershipHeroSubDe     String?  @map("membership_hero_sub_de")
  membershipHeroSubEn     String?  @map("membership_hero_sub_en")
  membershipHeroBgUrl     String?  @map("membership_hero_bg_url")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  @@map("site_config")
}

model BlogPost {
  id         String   @id @default(uuid())
  title      String
  body       String
  coverImage String?
  author     String   @default("Équipe Level Up in Germany")
  category   String?
  published  Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("blog_posts")
}

model TeamMember {
  id       String  @id @default(uuid())
  name     String  @unique
  roleDe   String? @default("")
  roleEn   String? @default("")
  roleFr   String? @default("")
  bioDe    String? @default("")
  bioEn    String? @default("")
  bioFr    String? @default("")
  linkedin String? @default("")
  imageUrl String? @default("")

  @@map("team_members")
}

model Media {
  id        String   @id @default(uuid())
  filename  String
  url       String
  altText   String?  @default("")
  category  String   @default("general")
  size      Int?
  mimeType  String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("media_files")
}

model Partner {
  id          String   @id @default(uuid())
  name        String
  logoUrl     String   @default("") @map("logo_url")
  websiteUrl  String?  @map("website_url")
  category    String   @default("partner") // partner | sponsor
  sortOrder   Int      @default(0) @map("sort_order")
  visible     Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([visible, sortOrder])
  @@map("partners")
}

model Venue {
  id            String             @id @default(uuid())
  name          String
  addressLine1  String
  postalCode    String?
  city          String
  country       String
  googleMapsUrl String?
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")
  events        Event[]
  translations  VenueTranslation[]

  @@index([city])
  @@map("venues")
}

model VenueTranslation {
  id               String  @id @default(uuid())
  venueId          String  @map("venue_id")
  locale           String
  displayName      String? @default("") @map("display_name")
  addressLabel     String? @default("") @map("address_label")
  cityLabel        String? @default("") @map("city_label")
  shortDescription String? @default("") @map("short_description")
  venue            Venue   @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@unique([venueId, locale])
  @@map("venue_translations")
}

model Event {
  id                 String              @id @default(uuid())
  year               Int                 @unique
  slug               String              @unique
  status             String              @default("draft")
  sortOrder          Int                 @default(0) @map("sort_order")
  startsAt           DateTime?           @map("starts_at")
  endsAt             DateTime?           @map("ends_at")
  timezone           String              @default("Europe/Berlin")
  isDateConfirmed    Boolean             @default(false) @map("is_date_confirmed")
  heroImageUrl       String?             @map("hero_image_url")
  heroBadge          String?             @map("hero_badge")
  primaryCtaUrl      String?             @map("primary_cta_url")
  secondaryCtaUrl    String?             @map("secondary_cta_url")
  contactEmail       String?             @map("contact_email")
  contactPhone       String?             @map("contact_phone")
  contactInstagram   String?             @map("contact_instagram")
  showPrice          Boolean             @default(true) @map("show_price")
  priceBlurred       Boolean             @default(false) @map("price_blurred")
  ticketingStatus    String              @default("coming_soon") @map("ticketing_status")
  publishedAt        DateTime?           @map("published_at")
  venueId            String?             @map("venue_id")
  deletedAt          DateTime?           @map("deleted_at")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  venue              Venue?              @relation(fields: [venueId], references: [id], onDelete: SetNull)
  translations       EventTranslation[]
  prices             EventPrice[]
  highlights         EventHighlight[]
  scheduleSections   ScheduleSection[]
  scheduleItems      ScheduleItem[]
  eventSpeakers      EventSpeaker[]
  eventOrganizations EventOrganization[]
  mediaItems         EventMedia[]
  documents          EventDocument[]
  communicationSetting CommunicationSettings?
  communicationLeads   EventCommunicationLead[]

  @@index([status, sortOrder])
  @@index([publishedAt])
  @@map("events")
}

model EventTranslation {
  id                String  @id @default(uuid())
  eventId           String  @map("event_id")
  locale            String
  name              String
  title             String
  subtitle          String? @default("")
  shortDescription  String? @default("") @map("short_description")
  longDescription   String? @default("") @map("long_description")
  heroText          String? @default("") @map("hero_text")
  audienceLabel     String? @default("") @map("audience_label")
  badgeText         String? @default("") @map("badge_text")
  primaryCtaLabel   String? @default("") @map("primary_cta_label")
  secondaryCtaLabel String? @default("") @map("secondary_cta_label")
  galleryIntro      String? @default("") @map("gallery_intro")
  ticketInfo        String? @default("") @map("ticket_info")
  pdfTitle          String? @default("") @map("pdf_title")
  pdfDescription    String? @default("") @map("pdf_description")
  seoTitle          String? @default("") @map("seo_title")
  seoDescription    String? @default("") @map("seo_description")
  dateFallbackLabel String? @default("") @map("date_fallback_label")
  dateTbaLabel      String? @default("") @map("date_tba_label")
  event             Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, locale])
  @@map("event_translations")
}

model EventPrice {
  id           String                  @id @default(uuid())
  eventId      String                  @map("event_id")
  type         String
  priceCents   Int?                    @map("price_cents")
  currency     String                  @default("EUR")
  purchaseUrl  String?                 @map("purchase_url")
  sortOrder    Int                     @default(0) @map("sort_order")
  isVisible    Boolean                 @default(true) @map("is_visible")
  createdAt    DateTime                @default(now()) @map("created_at")
  updatedAt    DateTime                @updatedAt @map("updated_at")
  event        Event                   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  translations EventPriceTranslation[]

  @@index([eventId, sortOrder])
  @@map("event_prices")
}

model EventHighlight {
  id           String                      @id @default(uuid())
  eventId      String                      @map("event_id")
  sortOrder    Int                         @default(0) @map("sort_order")
  isVisible    Boolean                     @default(true) @map("is_visible")
  createdAt    DateTime                    @default(now()) @map("created_at")
  updatedAt    DateTime                    @updatedAt @map("updated_at")
  event        Event                       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  translations EventHighlightTranslation[]

  @@index([eventId, sortOrder])
  @@map("event_highlights")
}

model EventHighlightTranslation {
  id               String         @id @default(uuid())
  eventHighlightId String         @map("event_highlight_id")
  locale           String
  title            String
  body             String?        @default("")
  eventHighlight   EventHighlight @relation(fields: [eventHighlightId], references: [id], onDelete: Cascade)

  @@unique([eventHighlightId, locale])
  @@map("event_highlight_translations")
}

model EventPriceTranslation {
  id           String     @id @default(uuid())
  eventPriceId String     @map("event_price_id")
  locale       String
  label        String
  infoText     String?    @default("") @map("info_text")
  eventPrice   EventPrice @relation(fields: [eventPriceId], references: [id], onDelete: Cascade)

  @@unique([eventPriceId, locale])
  @@map("event_price_translations")
}

model ScheduleSection {
  id           String                       @id @default(uuid())
  eventId      String                       @map("event_id")
  sortOrder    Int                          @default(0) @map("sort_order")
  createdAt    DateTime                     @default(now()) @map("created_at")
  updatedAt    DateTime                     @updatedAt @map("updated_at")
  event        Event                        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  translations ScheduleSectionTranslation[]
  items        ScheduleItem[]

  @@index([eventId, sortOrder])
  @@map("schedule_sections")
}

model ScheduleSectionTranslation {
  id                String          @id @default(uuid())
  scheduleSectionId String          @map("schedule_section_id")
  locale            String
  title             String
  subtitle          String?         @default("")
  scheduleSection   ScheduleSection @relation(fields: [scheduleSectionId], references: [id], onDelete: Cascade)

  @@unique([scheduleSectionId, locale])
  @@map("schedule_section_translations")
}

model ScheduleItem {
  id           String                    @id @default(uuid())
  eventId      String                    @map("event_id")
  sectionId    String?                   @map("section_id")
  startTime    String?                   @map("start_time")
  endTime      String?                   @map("end_time")
  blockType    String?                   @default("morning") @map("block_type")
  sessionType  String                    @default("other") @map("session_type")
  room         String?                   @default("")
  sortOrder    Int                       @default(0) @map("sort_order")
  createdAt    DateTime                  @default(now()) @map("created_at")
  updatedAt    DateTime                  @updatedAt @map("updated_at")
  event        Event                     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  section      ScheduleSection?          @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  translations ScheduleItemTranslation[]
  itemSpeakers ScheduleItemSpeaker[]

  @@index([eventId, sortOrder])
  @@index([sectionId, sortOrder])
  @@map("schedule_items")
}

model ScheduleItemTranslation {
  id             String       @id @default(uuid())
  scheduleItemId String       @map("schedule_item_id")
  locale         String
  title          String
  subtitle       String?      @default("")
  description    String?      @default("")
  scheduleItem   ScheduleItem @relation(fields: [scheduleItemId], references: [id], onDelete: Cascade)

  @@unique([scheduleItemId, locale])
  @@map("schedule_item_translations")
}

model Speaker {
  id            String                @id @default(uuid())
  slug          String                @unique
  firstName     String?               @map("first_name")
  lastName      String?               @map("last_name")
  displayName   String                @map("display_name")
  photoUrl      String?               @map("photo_url")
  linkedInUrl   String?               @map("linkedin_url")
  instagramUrl  String?               @map("instagram_url")
  websiteUrl    String?               @map("website_url")
  sortOrder     Int                   @default(0) @map("sort_order")
  isVisible     Boolean               @default(true) @map("is_visible")
  deletedAt     DateTime?             @map("deleted_at")
  createdAt     DateTime              @default(now()) @map("created_at")
  updatedAt     DateTime              @updatedAt @map("updated_at")
  translations  SpeakerTranslation[]
  eventLinks    EventSpeaker[]
  scheduleItems ScheduleItemSpeaker[]

  @@index([isVisible, sortOrder])
  @@map("speakers")
}

model SpeakerTranslation {
  id           String  @id @default(uuid())
  speakerId    String  @map("speaker_id")
  locale       String
  role         String? @default("")
  organization String? @default("")
  shortBio     String? @default("") @map("short_bio")
  longBio      String? @default("") @map("long_bio")
  speaker      Speaker @relation(fields: [speakerId], references: [id], onDelete: Cascade)

  @@unique([speakerId, locale])
  @@map("speaker_translations")
}

model EventSpeaker {
  id        String   @id @default(uuid())
  eventId   String   @map("event_id")
  speakerId String   @map("speaker_id")
  sortOrder Int      @default(0) @map("sort_order")
  isVisible Boolean  @default(true) @map("is_visible")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  speaker   Speaker  @relation(fields: [speakerId], references: [id], onDelete: Cascade)

  @@unique([eventId, speakerId])
  @@index([eventId, sortOrder])
  @@map("event_speakers")
}

model ScheduleItemSpeaker {
  id             String       @id @default(uuid())
  scheduleItemId String       @map("schedule_item_id")
  speakerId      String       @map("speaker_id")
  sortOrder      Int          @default(0) @map("sort_order")
  scheduleItem   ScheduleItem @relation(fields: [scheduleItemId], references: [id], onDelete: Cascade)
  speaker        Speaker      @relation(fields: [speakerId], references: [id], onDelete: Cascade)

  @@unique([scheduleItemId, speakerId])
  @@index([scheduleItemId, sortOrder])
  @@map("schedule_item_speakers")
}

model Organization {
  id           String                    @id @default(uuid())
  slug         String                    @unique
  name         String
  category     String                    @default("partner")
  logoUrl      String?                   @map("logo_url")
  websiteUrl   String?                   @map("website_url")
  sortOrder    Int                       @default(0) @map("sort_order")
  isVisible    Boolean                   @default(true) @map("is_visible")
  deletedAt    DateTime?                 @map("deleted_at")
  createdAt    DateTime                  @default(now()) @map("created_at")
  updatedAt    DateTime                  @updatedAt @map("updated_at")
  translations OrganizationTranslation[]
  eventLinks   EventOrganization[]

  @@index([category, isVisible, sortOrder])
  @@map("organizations")
}

model OrganizationTranslation {
  id               String       @id @default(uuid())
  organizationId   String       @map("organization_id")
  locale           String
  shortDescription String?      @default("") @map("short_description")
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, locale])
  @@map("organization_translations")
}

model EventOrganization {
  id             String       @id @default(uuid())
  eventId        String       @map("event_id")
  organizationId String       @map("organization_id")
  category       String       @default("partner")
  sortOrder      Int          @default(0) @map("sort_order")
  isVisible      Boolean      @default(true) @map("is_visible")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  event          Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([eventId, organizationId, category])
  @@index([eventId, category, sortOrder])
  @@map("event_organizations")
}

model EventMedia {
  id           String                  @id @default(uuid())
  eventId      String                  @map("event_id")
  type         String                  @default("gallery")
  url          String
  mimeType     String?                 @map("mime_type")
  size         Int?
  width        Int?
  height       Int?
  sortOrder    Int                     @default(0) @map("sort_order")
  isVisible    Boolean                 @default(true) @map("is_visible")
  createdAt    DateTime                @default(now()) @map("created_at")
  updatedAt    DateTime                @updatedAt @map("updated_at")
  event        Event                   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  translations EventMediaTranslation[]

  @@index([eventId, type, sortOrder])
  @@map("event_media")
}

model EventMediaTranslation {
  id           String     @id @default(uuid())
  eventMediaId String     @map("event_media_id")
  locale       String
  altText      String?    @default("") @map("alt_text")
  caption      String?    @default("")
  eventMedia   EventMedia @relation(fields: [eventMediaId], references: [id], onDelete: Cascade)

  @@unique([eventMediaId, locale])
  @@map("event_media_translations")
}

model EventDocument {
  id           String                     @id @default(uuid())
  eventId      String                     @map("event_id")
  type         String                     @default("event_book")
  url          String
  sortOrder    Int                        @default(0) @map("sort_order")
  isVisible    Boolean                    @default(true) @map("is_visible")
  createdAt    DateTime                   @default(now()) @map("created_at")
  updatedAt    DateTime                   @updatedAt @map("updated_at")
  event        Event                      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  translations EventDocumentTranslation[]

  @@index([eventId, type, sortOrder])
  @@map("event_documents")
}

model EventDocumentTranslation {
  id              String        @id @default(uuid())
  eventDocumentId String        @map("event_document_id")
  locale          String
  title           String
  description     String?       @default("")
  eventDocument   EventDocument @relation(fields: [eventDocumentId], references: [id], onDelete: Cascade)

  @@unique([eventDocumentId, locale])
  @@map("event_document_translations")
}
